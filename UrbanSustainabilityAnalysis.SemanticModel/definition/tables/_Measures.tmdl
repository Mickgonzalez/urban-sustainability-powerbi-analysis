	measure 'Page 1 - Card - Livability HTML' = ```
			
			"<div style='font-family:system-ui,sans-serif; background:white; border-radius:10px; position:absolute; inset:0; overflow:hidden; ms-overflow-style:none; scrollbar-width:none;'> " &
			  "<style> " &
			    "/* Blindaje contra scrollbars */ " &
			    "html, body { margin:0 !important; padding:0 !important; overflow:hidden !important; height:100%; width:100%; } " &
			    "::-webkit-scrollbar { display:none !important; width:0; background:transparent; } " &
			    
			    "/* Contenedor principal con padding interno */ " &
			    ".card-container { position:relative; width:100%; height:100%; overflow:hidden; padding:12px 14px; box-sizing:border-box; cursor:pointer; } " &
			    
			    "/* Animacion de subida */ " &
			    ".card-content { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); height:100%; width:100%; display:flex; flex-direction:column; } " &
			    ".card-container:hover .card-content { transform: translateY(-100%); } " &
			    
			    "/* Capa de informacion trasera (Quick Guide) */ " &
			    ".tooltip-overlay { " &
			        "position: absolute; top: 100%; left: 0; width: 100%; height: 100%; " &
			        "background: #0066CC; color: white; padding: 14px; " &
			        "transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); " &
			        "display: flex; flex-direction: column; justify-content: center; box-sizing: border-box; " &
			    "} " &
			    ".card-container:hover .tooltip-overlay { transform: translateY(-100%); } " &
			  "</style> " &
			
			  "<div class='card-container'> " &
			    
			    "" &
			    "<div class='card-content'> " &
			      "<div style='margin-bottom:8px'> " &
			        "<svg width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='#0066CC' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'> " &
			          "<path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'></path> " &
			          "<circle cx='9' cy='7' r='4'></circle> " &
			          "<path d='M23 21v-2a4 4 0 0 0-3-3.87'></path> " &
			          "<path d='M16 3.13a4 4 0 0 1 0 7.75'></path> " &
			        "</svg> " &
			      "</div> " &
			      
			      "<div style='font-size:25px; font-weight:700; color:#1a1a1a; line-height:1; margin-bottom:3px'> " & 
			        FORMAT([Avg Livability Score], "0.0") & 
			      "</div> " &
			      
			      "<div style='font-size:11px; font-weight:500; color:#666666; margin-bottom:10px'>Avg Livability Score</div> " &
			      
			      "<div style='padding-top:8px; border-top:1px solid #f0f0f0'> " &
			        "<div style='display:flex; justify-content:space-between; align-items:center; margin-bottom:6px'> " &
			          "<div style='font-size:9px; font-weight:600; color:#999999; text-transform:uppercase;'>All Cities Avg</div> " &
			          "<div style='font-size:13px; font-weight:600; color:#333333'>" & FORMAT([All Cities Avg Livability], "0.0") & "</div> " &
			        "</div> " &
			        "<div style='display:flex; justify-content:space-between; align-items:center'> " &
			          "<div style='font-size:9px; font-weight:600; color:#999999; text-transform:uppercase;'>Gap</div> " &
			          "<div style='font-size:13px; font-weight:700;" & IF([Gap Absolute] >= 0, "color:#0066CC", "color:#C75B5B") & "'>" & [Gap with Sign] & "</div> " &
			        "</div> " &
			      "</div> " &
			    "</div> " &
			
			    "" &
			    "<div class='tooltip-overlay'> " &
			      "<div style='font-size:12px; font-weight:700; margin-bottom:6px; border-bottom:1px solid rgba(255,255,255,0.3); padding-bottom:4px;'>Quick Guide</div> " &
