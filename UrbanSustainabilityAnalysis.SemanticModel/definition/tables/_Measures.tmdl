	measure 'Page 1 - Line Chart - Y Axis Max Smart' = ```
			
			VAR CityMin = MINX(ALL('City Metrics'[Year]), [Selected City Metric])
			VAR BenchmarkMin = MINX(ALL('City Metrics'[Year]), [All Cities Benchmark])
			VAR OverallMin = MIN(CityMin, BenchmarkMin)
			
			VAR CityMax = MAXX(ALL('City Metrics'[Year]), [Selected City Metric])
			VAR BenchmarkMax = MAXX(ALL('City Metrics'[Year]), [All Cities Benchmark])
			VAR OverallMax = MAX(CityMax, BenchmarkMax)
			
			VAR DataRange = OverallMax - OverallMin
			
			
			VAR PaddingPct = 
			    SWITCH(
			        TRUE(),
			        DataRange < 5, 0.15,     
			        DataRange < 10, 0.12,     
			        DataRange < 20, 0.10,     
			        0.08                      
			    )
			
			VAR Padding = DataRange * PaddingPct
			VAR AdjustedMin = OverallMin - Padding
			VAR AdjustedMax = OverallMax + Padding
			
			
			VAR RoundingFactor = 
			    SWITCH(
			        TRUE(),
			        DataRange < 10, 1,       
			        DataRange < 30, 2,       
			        5                        
			    )
			
			VAR SmartMin = FLOOR(AdjustedMin, RoundingFactor)
			VAR SmartMax = CEILING(AdjustedMax, RoundingFactor)
			
			RETURN
			SmartMax
			
			```
		formatString: 0
		lineageTag: 3d803bf8-2d7e-4be3-9eba-57d66c6d7930

