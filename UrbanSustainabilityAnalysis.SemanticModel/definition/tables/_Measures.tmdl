	measure 'Header - Main Title' = ```
			
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			
			VAR Title = 
			    SWITCH(
			        MetricOrder,
			        0, "Livability Index Analysis",
			        1, "Housing Affordability Analysis",
			        2, "Transit Quality Analysis",
			        3, "Green Space Analysis",
			        4, "Emissions Analysis",
			        "Select a Metric Below to Begin"
			    )
			
			RETURN
			Title
			
			```
		lineageTag: d95d99b7-9321-4b00-931e-fdd13f080aa8

	measure 'Header - Subtitle II' = ```
			
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			
			VAR Subtitle = 
			    SWITCH(
			        MetricOrder,
			        0, "Metric Selected: Livability Index - Composite score measuring overall city quality across housing, transit, environment, and emissions. Higher scores indicate better livability.",
			        1, "Metric Selected: Housing Affordability - Index measuring housing costs relative to income. Higher values indicate more affordable housing options for residents.",
			        2, "Metric Selected: Transit Quality - Score evaluating public transportation accessibility and quality. Higher scores reflect better transit infrastructure and connectivity.",
			        3, "Metric Selected: Green Space - Percentage of city area dedicated to parks and natural spaces. Higher values indicate more green space available per capita.",
			        4, "Metric Selected: Emissions - Index measuring air pollution and carbon emissions. Lower values indicate cleaner air and better environmental quality.",
			        "Choose from the metrics below to explore city performance trends and insights"
			    )
			
			RETURN
			Subtitle
			```
		lineageTag: 9a882dc2-5326-4eb3-b974-3db0940c4c61

	measure 'Page 1 - Header - Title and Context' = ```
			VAR SelectedCity = SELECTEDVALUE('City Lookup'[City], "All Cities")
			VAR SelectedMetricOrder = SELECTEDVALUE('Parameter'[Parameter Order], 0)
			VAR SelectedMetric = 
			    SWITCH(
			        SelectedMetricOrder,
			        0, "Livability Index",
			        1, "Housing Affordability",
			        2, "Transit Quality",
			        3, "Green Space",
			        4, "Emissions",
			        "Livability Index"
			    )
			VAR SelectedYear = SELECTEDVALUE('City Metrics'[Year], YEAR(TODAY()))
			
			RETURN
			"<div style='
			    font-family: Segoe UI, sans-serif;
			    padding: 0px;
			    line-height: 1;
			'>
			    <div style='
			        font-size: 22px;
			        font-weight: 600;
			        color: #0A1628;
			        margin-bottom: 8px;
			    '>Executive Summary</div>
			    <div style='
			        font-size: 12px;
			        color: #64748B;
			        font-weight: 400;
			    '>
			        <span style='color: #64748B;'>City:</span> 
			        <span style='font-weight: 600; color: #0A1628;'>" & SelectedCity & "</span>
			        <span style='margin: 0 8px; color: #CBD5E1;'>•</span>
			        <span style='color: #64748B;'>Metric:</span> 
			        <span style='font-weight: 600; color: #0066CC;'>" & SelectedMetric & "</span>
			        <span style='margin: 0 8px; color: #CBD5E1;'>•</span>
			        <span style='color: #64748B;'>Year:</span> 
			        <span style='font-weight: 600; color: #0A1628;'>" & SelectedYear & "</span>
			    </div>
			</div>"
			```
		lineageTag: 3c287dbe-0093-4fc3-baed-27c3fc5bb1ec

	measure 'All Cities Benchmark' = ```
			
