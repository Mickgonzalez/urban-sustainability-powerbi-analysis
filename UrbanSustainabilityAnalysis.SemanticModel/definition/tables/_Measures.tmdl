	measure 'Rank Context' =
			
			VAR TotalCitiesGlobal = CALCULATE(COUNTROWS('City Lookup'), ALL('City Lookup'))
			RETURN
			"out of " & TotalCitiesGlobal & " cities"
		lineageTag: ac4c914d-cce2-44cd-b005-6df6ed39585d

	measure 'Performance Tier' = ```
			
			
			VAR RankGlobal = 
			    RANKX(
			        ALL('City Lookup'[City]), 
			        [Avg Livability Score], 
			        , 
			        DESC, 
			        DENSE
			    )
			
			
			VAR TotalGlobal = CALCULATE(COUNTROWS('City Lookup'), ALL('City Lookup'[City]))
			
			
			VAR Percentile = DIVIDE(RankGlobal, TotalGlobal)
			
			RETURN
			SWITCH(
			    TRUE(),
			    ISBLANK([Avg Livability Score]), BLANK(),
			    Percentile <= 0.33, "Upper Tier",
			    Percentile <= 0.66, "Middle Tier",
			    "Lower Tier"
			)
			
			```
		lineageTag: c9f610fc-278c-4d6a-ad8f-da1c1253e34c

	measure 'City Rank' = ```
			
