	measure 'Page 1 - Card - Strongest Dimension HTML' = ```
			
			VAR RawGapText = [Strongest Dimension Gap]
			VAR GapValue = IFERROR(VALUE(PATHITEM(SUBSTITUTE(RawGapText, " ", "|"), 1)), 0)
			VAR DimName = [Strongest Dimension Name]
			VAR UniqueID = "strongest_card"
			
			VAR IsGood = 
			    SWITCH(TRUE(),
			        ISBLANK(RawGapText), 1,
			        (DimName = "Housing Affordability" || DimName = "Emissions") && GapValue <= 0, 1,
			        (DimName = "Housing Affordability" || DimName = "Emissions") && GapValue > 0, 0,
			        GapValue >= 0, 1, 
			        0
			    )
			VAR MainColor = IF(IsGood = 1, "#0066CC", "#C75B5B")
			
			VAR IconSVG = 
			    SWITCH(TRUE(),
			        DimName = "Transit Quality" || DimName = "Transit Score" || DimName = "Transit", 
			            "<path d='M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2'></path>" &
			            "<circle cx='7' cy='17' r='2'></circle>" &
			            "<path d='M9 17h6'></path>" &
			            "<circle cx='17' cy='17' r='2'></circle>",
			        DimName = "Green Space",
			            "<path d='M12 19V5M5 11l7-7 7 7M8 15l4-4 4 4M12 19h-1m1 0h1'></path>",
			        DimName = "Emissions",
			            "<path d='M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z'></path>" &
			            "<path d='M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12'></path>",
			        DimName = "Housing Affordability",
			            "<path d='M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z'></path><polyline points='9 22 9 12 15 12 15 22'></polyline>",
			        DimName = "Livability Index" || DimName = "Livability",
			            "<path d='M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2'></path>" &
			            "<circle cx='9' cy='7' r='4'></circle>" &
			            "<path d='M23 21v-2a4 4 0 0 0-3-3.87'></path>" &
			            "<path d='M16 3.13a4 4 0 0 1 0 7.75'></path>",
			        "<path d='M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z'></path>" &
			        "<path d='M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12'></path>"
			    )
			
			VAR TooltipDescription = 
			    SWITCH(DimName,
			        "Housing Affordability", "This city offers highly competitive housing costs relative to the benchmark, attracting talent and residents.",
			        "Emissions", "Leading the way in sustainability with lower-than-average emissions per capita.",
			        "Transit Quality", "Superior public infrastructure. High connectivity scores provide a major competitive advantage.",
			        "Livability Index", "Exceptional quality of life metrics. This city outperforms others in essential services and safety.",
			        "Green Space", "Abundant access to parks and natural areas, significantly higher than the regional average.",
			        "This is the city's top-performing category relative to the global benchmark."
			    )
			
			RETURN
			"<div style='font-family:system-ui,sans-serif; background:white; border-radius:10px; position:absolute; inset:0; overflow:hidden; ms-overflow-style:none; scrollbar-width:none;'> " &
			  "<style> " &
			    "html, body { margin:0 !important; padding:0 !important; overflow:hidden !important; height:100%; width:100%; } " &
			    "::-webkit-scrollbar { display:none !important; width:0; } " &
			    
			    ".cont-str { position:relative; width:100%; height:100%; overflow:hidden; padding:12px 14px; box-sizing:border-box; cursor:pointer; } " &
			    
			    ".c-str { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); height:100%; width:100%; display:flex; flex-direction:column; } " &
			    ".cont-str:hover .c-str { transform: translateY(-100%); } " &
			    
			    ".tt-str { " &
			        "position: absolute; top: 100%; left: 0; width: 100%; height: 100%; " &
			        "background: " & MainColor & "; color: white; padding: 14px; " &
			        "transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); " &
			        "display: flex; flex-direction: column; justify-content: center; box-sizing: border-box; " &
			    "} " &
			    ".cont-str:hover .tt-str { transform: translateY(-100%); } " &
			  "</style> " &
			
			  "<div class='cont-str'> " &
			    
			    "" &
			    "<div class='c-str'> " &
			      "<div style='margin-bottom:8px'> " &
			        "<svg width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='" & MainColor & "' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'> " &
			          IconSVG &
			        "</svg> " &
			      "</div> " &
			      
			      "<div style='font-size:16px; font-weight:700; color:#1a1a1a; line-height:1.2; margin-bottom:8px'> " &
			        IF(ISBLANK(DimName), "N/A", DimName) &
			      "</div> " &
			      
			      "<div style='font-size:11px; font-weight:500; color:#666666; margin-bottom:10px'>Strongest Dimension</div> " &
			      
			      "<div style='padding-top:8px; border-top:1px solid #f0f0f0'> " &
			        "<div style='display:flex; justify-content:space-between; align-items:center; margin-bottom:6px'> " &
			          "<div style='font-size:9px; font-weight:600; color:#999999; text-transform:uppercase;'>Dimension Value</div> " &
			          "<div style='font-size:13px; font-weight:600; color:#333333'>" & 
			            IF(ISBLANK([Strongest Dimension Value]), "-", FORMAT([Strongest Dimension Value], "0.00")) & 
			          "</div> " &
			        "</div> " &
			        
			        "<div style='display:flex; justify-content:space-between; align-items:center'> " &
			          "<div style='font-size:9px; font-weight:600; color:#999999; text-transform:uppercase;'>Gap vs Avg</div> " &
			          "<div style='font-size:13px; font-weight:700; color:" & MainColor & "'>" & 
			            IF(ISBLANK(RawGapText), "-", RawGapText) & 
			          "</div> " &
			        "</div> " &
			      "</div> " &
			    "</div> " &
			
			    "" &
			    "<div class='tt-str'> " &
			      "<div style='font-size:12px; font-weight:700; margin-bottom:6px; border-bottom:1px solid rgba(255,255,255,0.3); padding-bottom:4px;'>" & DimName & "</div> " &
			      "<p style='font-size:10px; line-height:1.4; margin:0; font-weight:400;'> " &
			        TooltipDescription &
			      "</p> " &
			      "<div style='margin-top:10px; font-size:9px; opacity:0.85;'>This represents your most significant competitive advantage.</div> " &
			    "</div> " &
			
			  "</div> " &
			"</div>"
			```
		lineageTag: b31164f3-d56b-4a65-8a36-c6f963d4fed0

	measure 'Strongest Dimension Gap' = ```
			
			VAR DimensionName = [Strongest Dimension Name]
			VAR CurrentValue = [Strongest Dimension Value]
			
			VAR AvgValue = 
			SWITCH(
			    DimensionName,
			    "Housing Affordability", CALCULATE([Avg Housing Affordability], ALL('City Lookup'[City])),
			    "Transit Score", CALCULATE([Avg Transit Score], ALL('City Lookup'[City])),
			    "Green Space", CALCULATE([Avg Green Space], ALL('City Lookup'[City])),
			    "Emissions", CALCULATE([Avg Emissions], ALL('City Lookup'[City])),
			    BLANK()
			)
			
			VAR Gap = CurrentValue - AvgValue
			VAR Sign = IF(Gap >= 0, "+", "")
			
			RETURN
			Sign & FORMAT(Gap, "0.0") & " vs avg"
			
			```
		lineageTag: a4aefd72-0382-450a-a2d3-1c8a23096133

	measure 'Strongest Dimension Name' = ```
			
			VAR HousingScore = [Avg Housing Affordability]
			VAR TransitScore = [Avg Transit Score]
			VAR GreenScore = [Avg Green Space]
			VAR EmissionsScore = [Avg Emissions]  
			
			VAR HousingAvg = CALCULATE([Avg Housing Affordability], ALL('City Lookup'[City]))
			VAR TransitAvg = CALCULATE([Avg Transit Score], ALL('City Lookup'[City]))
			VAR GreenAvg = CALCULATE([Avg Green Space], ALL('City Lookup'[City]))
			VAR EmissionsAvg = CALCULATE([Avg Emissions], ALL('City Lookup'[City])) 
			
			
			VAR HousingGapRaw = HousingScore - HousingAvg
			VAR TransitGapRaw = TransitScore - TransitAvg
			VAR GreenGapRaw = GreenScore - GreenAvg
			VAR EmissionsGapRaw = EmissionsScore - EmissionsAvg
			
			
			VAR HousingGap = HousingGapRaw * -1  
			VAR TransitGap = TransitGapRaw       
			VAR GreenGap = GreenGapRaw           
			VAR EmissionsGap = EmissionsGapRaw * -1  
			
			VAR MaxGap = MAX(HousingGap, MAX(TransitGap, MAX(GreenGap, EmissionsGap)))
			
			RETURN
			SWITCH(
			    TRUE(),
			    MaxGap = HousingGap, "Housing Affordability",
			    MaxGap = TransitGap, "Transit Score",
			    MaxGap = GreenGap, "Green Space",
			    MaxGap = EmissionsGap, "Emissions",
			    BLANK()
			)
			```
		lineageTag: c282e038-6254-4fbc-9401-0f87da7a7a25

