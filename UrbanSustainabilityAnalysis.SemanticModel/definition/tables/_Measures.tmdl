	measure 'Page 1 - Bar Chart Color' = ```
			
			
			VAR CidadeNoEixo = SELECTEDVALUE('City Slicer'[City])
			
			
			VAR CidadeSelecionadaNoSlicer = SELECTEDVALUE('City Lookup'[City])
			
			
			VAR ValorDaBarra = [Bar Chart Value Display]
			
			
			VAR BenchmarkValue = [All Cities Benchmark]
			VAR Gap = ValorDaBarra - BenchmarkValue
			
			RETURN
			IF(
			  
			    CidadeNoEixo = CidadeSelecionadaNoSlicer && NOT(ISBLANK(CidadeSelecionadaNoSlicer)),
			    "#0066CC",
			    
			 
			    SWITCH(
			        TRUE(),
			        ISBLANK(ValorDaBarra), "#F0F0F0", 
			        Gap > 2, "#4A5D66",  
			        Gap > 0, "#6A7E88",  
			        Gap > -2, "#A0B1BA", 
			        "#C5D1D8"             
			    )
			)
			
			```
		lineageTag: 18f4419d-4b98-4ecc-b389-9bf915876b5e

	measure 'Page 1 - Bar Chart - Title' = ```
			
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			VAR MetricName = 
			    SWITCH(
			        MetricOrder,
			        0, "Livability Index",
			        1, "Housing Affordability",
			        2, "Transit Quality",
			        3, "Green Space",
			        4, "Emissions",
			        "Selected Metric"
			    )
			VAR CurrentYear = MAX('City Metrics'[Year])
			
			
			VAR TopCityTable = 
			    ADDCOLUMNS(
			        ALL('City Lookup'[City]),
			        "@Value", CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			    )
			VAR TopCity = TOPN(1, TopCityTable, [@Value], DESC)
			VAR TopCityName = MAXX(TopCity, 'City Lookup'[City])
			VAR TopValue = MAXX(TopCity, [@Value])
			
			
			VAR BottomCity = TOPN(1, TopCityTable, [@Value], ASC)
			VAR BottomCityName = MAXX(BottomCity, 'City Lookup'[City])
			VAR BottomValue = MAXX(BottomCity, [@Value])
			
			
			VAR CityGap = TopValue - BottomValue
			VAR GapPct = DIVIDE(CityGap, BottomValue, 0)
			
			VAR TitleText = 
			    TopCityName & " leads in " & MetricName & 
			    " (" & FORMAT(TopValue, "0.0") & " pts) ⁕ " &
			    FORMAT(GapPct, "0.0%") & " ahead of " & BottomCityName
			
			RETURN
			TitleText
			
			```
		lineageTag: 6649800e-9ee3-4318-9fb6-5611fa6538c0

	measure 'Page 1 - Bar Chart - Subtitle' = ```
			
			VAR CurrentYear = MAX('City Metrics'[Year])
			VAR BenchmarkValue = 
			    CALCULATE(
			        [All Cities Benchmark],
			        'City Metrics'[Year] = CurrentYear
			    )
			
			VAR CitiesAbove = 
			    COUNTROWS(
			        FILTER(
			            ALL('City Lookup'[City]),
			            CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear) > BenchmarkValue
			        )
			    )
			VAR CitiesBelow = 
			    COUNTROWS(
			        FILTER(
			            ALL('City Lookup'[City]),
			            CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear) < BenchmarkValue
			        )
			    )
			
			VAR PrevYear = CurrentYear - 1
			VAR CitiesWithGrowth = 
			    ADDCOLUMNS(
			        ALL('City Lookup'[City]),
			        "@CurrentValue", CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear),
			        "@PrevValue", CALCULATE([Selected Metric], 'City Metrics'[Year] = PrevYear),
			        "@Growth", 
			            CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear) - 
			            CALCULATE([Selected Metric], 'City Metrics'[Year] = PrevYear)
			    )
			VAR TopGrower = TOPN(1, CitiesWithGrowth, [@Growth], DESC)
			VAR TopGrowerName = MAXX(TopGrower, 'City Lookup'[City])
			VAR TopGrowth = MAXX(TopGrower, [@Growth])
			
			
			VAR DistributionText = 
			    CitiesAbove & " cities above average (" & FORMAT(BenchmarkValue, "0.0") & "), " &
			    CitiesBelow & " below"
			
			
			VAR GrowthText = 
			    IF(
			        NOT(ISBLANK(TopGrowth)) && TopGrowth > 0,
			        " • Best YoY: " & TopGrowerName & " (" & FORMAT(TopGrowth, "+0.0") & " pts)",
			        ""
			    )
			
			VAR SubtitleText = 
			    DistributionText & GrowthText & " • Year: " & CurrentYear
			
			RETURN
			SubtitleText
			
			```
		lineageTag: c7805af8-3b62-4de1-bd0b-9fadac7d2c23

