	measure 'Field Parameter - Icon URL' = ```
			
			
			// Free to use, no attribution required in most cases
			
			VAR _livability_photo = "https://jjkpkhxeiwvpmywqvhgo.supabase.co/storage/v1/object/public/public-assets/Power%20BI%20World%20Champs%2026%20Assets/modern-city-skyline-silhouette-at-blue-h_Z23tigWaTPO7I6PBrwkYbQ_we3aANIpQ8a28C-QnABc7w.png"
			
			
			VAR _housing_photo = "https://jjkpkhxeiwvpmywqvhgo.supabase.co/storage/v1/object/public/public-assets/Power%20BI%20World%20Champs%2026%20Assets/residential-neighborhood-rooftops-at-blu_eXM-ycaRT4KKaD2IDK-7Dw_h8H49YvORbuobMkqHV41zw.png"
			
			
			VAR _transit_photo = "https://jjkpkhxeiwvpmywqvhgo.supabase.co/storage/v1/object/public/public-assets/Power%20BI%20World%20Champs%2026%20Assets/modern-transit-bus-or-train-in-twilight-_YMQ8Ij3lQmumNxU5nE_xrg_NpO_hW1sQ96OBRMxGFGvHw.png"
			
			
			VAR _greenspace_photo = "https://images.unsplash.com/photo-1441974231531-c6227db76b6e?w=400&q=80"
			
			
			VAR _emissions_photo = "https://jjkpkhxeiwvpmywqvhgo.supabase.co/storage/v1/object/public/public-assets/Power%20BI%20World%20Champs%2026%20Assets/industrial-smokestacks-with-soft-steam-a_t1wezITGQySc6L6vXGhRQg_yuwFaQ5zQoOmLVd9OYNw_g.png"
			
			
			RETURN
			SWITCH(
			    SELECTEDVALUE('Parameter'[Parameter Order]),
			    0, _livability_photo,
			    1, _housing_photo,
			    2, _transit_photo,
			    3, _greenspace_photo,
			    4, _emissions_photo,
			    BLANK()
			)
			
			/* ICONIFY CDN VERSION - COMMENTED FOR FUTURE USE
			VAR _livability_img = "https://api.iconify.design/mdi/star-circle.svg?color=%23FFB338&width=64&height=64"
			VAR _housing_img = "https://api.iconify.design/mdi/home-circle.svg?color=%232196F3&width=64&height=64"
			VAR _transit_img = "https://api.iconify.design/mdi/train.svg?color=%234CAF50&width=64&height=64"
			VAR _greenspace_img = "https://api.iconify.design/mdi/tree.svg?color=%2366BB6A&width=64&height=64"
			VAR _emissions_img = "https://api.iconify.design/mdi/factory.svg?color=%23FF5722&width=64&height=64"
			*/
			
			/* INLINE SVG VERSION - ALSO AVAILABLE
			VAR _livability = "data:image/svg+xml;utf8,<svg width='100' height='100' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24'><path d='M12 2 L15.09 8.26 L22 9.27 L17 14.14 L18.18 21 L12 17.77 L5.82 21 L7 14.14 L2 9.27 L8.91 8.26 Z' fill='%23FFB338' stroke='%23FF9800' stroke-width='0.5' stroke-linejoin='round'/></svg>"
			*/
			
			```
		lineageTag: eee2a3a0-ddac-4c30-8231-ec0d66a276c9

	measure 'Field Parameter - Description Short' = ```
			
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			
			VAR ShortDesc = 
			    SWITCH(
			        MetricOrder,
			        0, "Overall city quality score across multiple dimensions",
			        1, "Housing cost affordability relative to local income",
			        2, "Public transportation accessibility and quality",
			        3, "City area dedicated to parks and green spaces",
			        4, "Air pollution and carbon emissions levels",
			        "Select a metric"
			    )
			
			RETURN
			ShortDesc
			
			```
		lineageTag: 94620dbc-aea8-4673-972f-d1605f44599b

