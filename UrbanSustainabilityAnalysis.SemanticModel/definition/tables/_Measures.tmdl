			VAR TooltipDescription = 
			    SWITCH(DimName,
			        "Housing Affordability", "High costs create a burden for residents. Lowering this index improves city accessibility.",
			        "Emissions", "High pollution levels detected. Reducing greenhouse gases is critical for sustainability.",
			        "Transit Quality", "Public transport availability is below average. Enhancing connectivity is a priority.",
			        "Livability Index", "Overall quality of life metrics are lagging. Improvements in services are needed.",
			        "Green Space", "Low access to parks and nature. Urban reforestation could boost this score.",
			        "This is the area with the lowest relative performance compared to the city average."
			    )
			
			RETURN
			"<div style='font-family:system-ui,sans-serif;background:white;border-radius:10px;padding:12px 14px;position:relative;overflow:hidden;height:100%;cursor:pointer;'>" &
			
			  "<style>" &
			   "body { overflow: hidden !important; }" &
			    ".c-weak { transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }" &
			    ".cont-weak:hover .c-weak { transform: translateY(-100%); }" &
			    ".tt-weak { " &
			        "position: absolute; top: 100%; left: 0; width: 100%; height: 100%; " &
			        "background: " & MainColor & "; color: white; padding: 14px; " &
			        "transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); " &
			        "display: flex; flex-direction: column; justify-content: center; box-sizing: border-box;" &
			    "}" &
			    ".cont-weak:hover .tt-weak { transform: translateY(-100%); }" &
			  "</style>" &
			
			  "<div class='cont-weak' style='position:relative;width:100%;height:100%;overflow:hidden;'>" &
			    
			    "" &
			    "<div class='c-weak' style='height:100%;'>" &
			      "<div style='margin-bottom:8px'>" &
			        "<svg width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='" & MainColor & "' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'>" &
			          IconSVG &
			        "</svg>" &
			      "</div>" &
			      
			      "<div style='font-size:16px;font-weight:700;color:#1a1a1a;line-height:1.2;margin-bottom:8px'>" &
			        IF(ISBLANK(DimName), "N/A", DimName) &
			      "</div>" &
			      
			      "<div style='font-size:11px;font-weight:500;color:#666666;margin-bottom:10px'>Weakest Dimension</div>" &
			      
			      "<div style='padding-top:8px;border-top:1px solid #f0f0f0'>" &
			        "<div style='display:flex;justify-content:space-between;align-items:center;margin-bottom:6px'>" &
			          "<div style='font-size:9px;font-weight:600;color:#999999;text-transform:uppercase;'>Dimension Value</div>" &
			          "<div style='font-size:13px;font-weight:600;color:#333333'>" &
			            IF(ISBLANK([Weakest Dimension Value]), "-", [Weakest Dimension Value]) &
			          "</div>" &
			        "</div>" &
			        
			        "<div style='display:flex;justify-content:space-between;align-items:center'>" &
			          "<div style='font-size:9px;font-weight:600;color:#999999;text-transform:uppercase;'>Gap vs Avg</div>" &
			          "<div style='font-size:13px;font-weight:700; color:" & MainColor & "'>" &
			            IF(ISBLANK(RawGapText), "-", RawGapText) &
			          "</div>" &
			        "</div>" &
			      "</div>" &
			    "</div>" &
			
			    "" &
			    "<div class='tt-weak'>" &
			      "<div style='font-size:12px;font-weight:700;margin-bottom:6px;border-bottom:1px solid rgba(255,255,255,0.3);padding-bottom:4px;'>" & DimName & "</div>" &
			      "<p style='font-size:10px;line-height:1.4;margin:0;font-weight:400;'>" &
			        TooltipDescription &
			      "</p>" &
			      "<div style='margin-top:10px; font-size:9px; opacity:0.85;'>Analysis based on " & FORMAT(GapValue/100, "0%") & " variance from global benchmark.</div>" &
			    "</div>" &
			
			  "</div>" &
			"</div>"
			```
		lineageTag: 2b5c18c8-3194-4bc1-9691-e9b71fa38fa6

	measure 'Page 1 - Line Chart - HTML Header V2' = ```
			
			VAR CityName = SELECTEDVALUE('City Lookup'[City], "All Cities")
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			VAR MetricName = 
			    SWITCH(
			        MetricOrder,
			        0, "Livability Index",
			        1, "Housing Affordability",
			        2, "Transit Quality",
			        3, "Green Space",
			        4, "Emissions"
			    )
			VAR TrendValue = [Analysis - Trend Direction]
			VAR PctChange = [Analysis - Period Change %]
			VAR YoYChange = [Analysis - YoY Change]
			VAR CurrentYear = MAX('City Metrics'[Year])
			
			
			VAR IsNegativeBenefit = MetricOrder = 1 || MetricOrder = 4 
			VAR IsPositiveBenefit = MetricOrder = 0 || MetricOrder = 2 || MetricOrder = 3
			
			VAR ColorPrimary = 
			    SWITCH(TRUE(),
			        IsPositiveBenefit && PctChange >= 0, "#0066CC",
			        IsPositiveBenefit && PctChange < 0, "#C62828",
			        IsNegativeBenefit && PctChange <= 0, "#0066CC",
			        IsNegativeBenefit && PctChange > 0, "#C62828",
			        "#0066CC"
			    )
			
			VAR TrendIcon = 
			    SWITCH(
			        TRUE(),
			        PctChange >= 0, 
			            "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='" & ColorPrimary & "' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' style='vertical-align:-3px;margin-left:6px'><polyline points='23 6 13.5 15.5 8.5 10.5 1 18'/><polyline points='17 6 23 6 23 12'/></svg>",
			        PctChange < 0, 
			            "<svg width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='" & ColorPrimary & "' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round' style='vertical-align:-3px;margin-left:6px'><polyline points='23 18 13.5 8.5 8.5 13.5 1 6'/><polyline points='17 18 23 18 23 12'/></svg>",
			        ""
			    )
			
			RETURN
			"<style>
			    @keyframes fadeInUp {
			        from { opacity: 0; transform: translateY(8px); }
			        to { opacity: 1; transform: translateY(0); }
			    }
			    .animate-fade { 
			        animation: fadeInUp 0.8s ease-out forwards; 
			    }
			</style>
			
			<div class='animate-fade' style='font-family:system-ui,sans-serif;padding:8px 0;background:transparent;position:relative;line-height:1.2'>" &
			  
			  "<div style='display:inline-block;background:#0066CC;color:white;padding:3px 12px;border-radius:14px;font-size:11px;font-weight:600;margin-bottom:8px;box-shadow:0 2px 6px rgba(0,102,204,0.25)'>" & 
			    CityName &
			  "</div>" &
			  
			  "<div style='font-size:17px;font-weight:700;color:#1a1a1a;margin-bottom:6px;padding-right:250px;line-height:1.3'>" & 
			    MetricName & " is " & TrendValue & TrendIcon &
			  "</div>" &
			  
			  "<div style='font-size:17px;font-weight:700;margin-bottom:10px;padding-right:250px;line-height:1.3'>" &
			    "<span style='color:" & ColorPrimary & ";display:inline-block'>" & FORMAT(PctChange, "+0.0%;-0.0%") & "</span> <span style='font-weight:500;color:#666666'>over 10 years</span>" &
			  "</div>" &
			  
			  "<div style='font-size:11px;color:#666666;font-weight:400;line-height:1.4'>" & 
			    "YoY (" & (CurrentYear - 1) & "–" & CurrentYear & "): <span style='font-weight:600;color:#333333'>" & FORMAT(YoYChange, "+0.0;-0.0") & " pts</span> • " &
			    FORMAT([Analysis - Years Above Average], "0") & " of 10 years above avg" &
			  "</div>" &
			  
			"</div>"
			```
		lineageTag: 1f320f93-eaa3-4062-94f4-4282947004a5

	measure 'Analysis - Trend Direction' = ```
			
			VAR FirstYear = CALCULATE([Selected City Metric], 'City Metrics'[Year] = 2015)
			VAR LastYear = CALCULATE([Selected City Metric], 'City Metrics'[Year] = 2024)
			VAR Change = LastYear - FirstYear
			
			RETURN
			SWITCH(
			    TRUE(),
			    Change > 2, "improving",
			    Change < -2, "declining",
			    "stable"
			)
			
			```
		lineageTag: f72c35d5-c8ed-4833-85aa-82b15d31b425

	measure 'Analysis - Period Change %' = ```
			
			VAR FirstYear = CALCULATE([Selected City Metric], 'City Metrics'[Year] = 2015)
			VAR LastYear = CALCULATE([Selected City Metric], 'City Metrics'[Year] = 2024)
			VAR Change = LastYear - FirstYear
			VAR PctChange = DIVIDE(Change, FirstYear, 0)
			
			RETURN
			PctChange
			
			```
		lineageTag: 2e7b7a5a-d76a-4362-a7fb-894f8e999cc0

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Analysis - YoY Change' = ```
			
			VAR MaxYear = MAX('City Metrics'[Year])
			VAR PrevYear = MaxYear - 1
			
			VAR ValueCurrent = CALCULATE([Selected City Metric], 'City Metrics'[Year] = MaxYear)
			VAR ValuePrevious = CALCULATE([Selected City Metric], 'City Metrics'[Year] = PrevYear)
			VAR YoYChange = ValueCurrent - ValuePrevious
			
			RETURN
			YoYChange
			
			```
		lineageTag: 02c99f93-5d90-4b78-b7cf-b92879ecab63

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Analysis - Years Above Average' = ```
			
			COUNTROWS(
			    FILTER(
			        ALL('City Metrics'[Year]),
			        [Selected City Metric] > [All Cities Benchmark]
			    )
			)
			
			```
		formatString: 0
		lineageTag: b7f9aea7-bf0d-4fbe-9d8b-298c69adff48

	measure 'Page 1 - Bar Chart - HTML Header V2' = ```
			
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			VAR MetricName = 
			    SWITCH(
			        MetricOrder,
			        0, "Livability Index",
			        1, "Housing Affordability",
			        2, "Transit Quality",
			        3, "Green Space",
			        4, "Emissions"
			    )
			VAR CurrentYear = MAX('City Metrics'[Year])
			
			
			VAR TopCityTable = 
			    ADDCOLUMNS(
			        ALL('City Lookup'[City]),
			        "@Value", CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			    )
			
			VAR TopCity = TOPN(1, TopCityTable, [@Value], DESC)
			VAR TopCityName = MAXX(TopCity, 'City Lookup'[City])
			VAR TopValue = MAXX(TopCity, [@Value])
			
			
			VAR SelectedCityName = SELECTEDVALUE('City Lookup'[City])
			VAR SelectedValue = CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			
			
			VAR BenchmarkValue = CALCULATE([All Cities Benchmark], 'City Metrics'[Year] = CurrentYear)
			
			
			VAR GapVsBenchmark = DIVIDE(SelectedValue - BenchmarkValue, BenchmarkValue, 0)
			
			
			VAR IsAboveBenchmark = (SelectedValue > BenchmarkValue)
			VAR IsNegativeBenefit = MetricOrder = 1 || MetricOrder = 4 
			
			VAR ColorGap = 
			    SWITCH(TRUE(),
			        NOT(IsNegativeBenefit) && IsAboveBenchmark, "#0066CC",
			        NOT(IsNegativeBenefit) && NOT(IsAboveBenchmark), "#C62828",
			        IsNegativeBenefit && NOT(IsAboveBenchmark), "#0066CC",
			        IsNegativeBenefit && IsAboveBenchmark, "#C62828",
			        "#0066CC"
			    )
			
			
			VAR CitiesAbove = COUNTROWS(FILTER(TopCityTable, [@Value] > BenchmarkValue))
			
			RETURN
			"<style>
			    @keyframes fadeInUp {
			        from { opacity: 0; transform: translateY(8px); }
			        to { opacity: 1; transform: translateY(0); }
			    }
			    .animate-bar-header { 
			        animation: fadeInUp 0.8s ease-out forwards; 
			    }
			</style>
			
			<div class='animate-bar-header' style='font-family:system-ui,sans-serif;padding:8px 0;background:transparent;position:relative;line-height:1.2'>" &
			  
			  "<div style='display:inline-block;background:linear-gradient(135deg,#0066CC,#004C99);color:white;padding:3px 12px;border-radius:14px;font-size:11px;font-weight:600;margin-bottom:8px;box-shadow:0 1px 4px rgba(0,102,204,0.2)'>" & 
			    SelectedCityName &
			  "</div>" &
			  
			  "<div style='font-size:17px;font-weight:700;color:#1a1a1a;margin-bottom:6px;padding-right:250px;line-height:1.3'>" & 
			    MetricName & " <span style='color:#0066CC;font-weight:600'>(" & FORMAT(SelectedValue, "0.0") & " pts)</span>" &
			  "</div>" &
			  
			  "<div style='font-size:17px;font-weight:700;margin-bottom:10px;padding-right:250px;line-height:1.3'>" &
			    "<span style='color:" & ColorGap & "'>" & 
			        IF(GapVsBenchmark >= 0, "+", "-") & FORMAT(ABS(GapVsBenchmark), "0.0%") & 
			    "</span>" &
			    " <span style='font-weight:500;color:#666666'>" & 
			        IF(IsAboveBenchmark, "above", "below") & " benchmark" &
			    "</span>" &
			  "</div>" &
			  
			  "<div style='font-size:11px;color:#666666;font-weight:400;line-height:1.4'>" & 
			    CitiesAbove & " cities above avg (" & FORMAT(BenchmarkValue, "0.0") & " pts) • " & TopCityName & " leads (" & FORMAT(TopValue, "0.0") & ") • Year: " & CurrentYear &
			  "</div>" &
			  
			"</div>"
			```
		lineageTag: 1c79ae53-2ed4-429c-a48b-ffbe6c898d71

	measure 'Page 1 - Table - HTML Header V2' = ```
			
			VAR MetricOrder = SELECTEDVALUE('Parameter'[Parameter Order])
			VAR MetricName =
			    SWITCH(
			        MetricOrder,
			        0, "Livability Index",
			        1, "Housing Affordability",
			        2, "Transit Quality",
			        3, "Green Space",
			        4, "Emissions",
			        "Selected Metric"
			    )
			VAR CurrentYear = MAX('City Metrics'[Year])
			
			
			VAR SelectedCityName = SELECTEDVALUE('City Lookup'[City])
			VAR SelectedValue = CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			
			
			VAR CityRank = 
			    RANKX(
			        ALL('City Lookup'[City]),
			        CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear),
			        ,
			        DESC,
			        DENSE
			    )
			
			
			VAR PrevYear = CurrentYear - 1
			VAR CitiesWithGrowth =
			    ADDCOLUMNS(
			        ALL('City Lookup'[City]),
			        "@Growth",
			        CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear) -
			        CALCULATE([Selected Metric], 'City Metrics'[Year] = PrevYear)
			    )
			VAR TopImprover = TOPN(1, CitiesWithGrowth, [@Growth], DESC)
			VAR TopImproverName = MAXX(TopImprover, 'City Lookup'[City])
			VAR TopImprovementValue = MAXX(TopImprover, [@Growth])
			
			RETURN
			"<style>
			    @keyframes fadeInUp {
			        from { opacity: 0; transform: translateY(8px); }
			        to { opacity: 1; transform: translateY(0); }
			    }
			    .animate-header { 
			        animation: fadeInUp 0.8s ease-out forwards; 
			    }
			</style>
			
			<div class='animate-header' style='font-family:system-ui,sans-serif;padding:8px 0;background:transparent;position:relative;line-height:1.2'>" &
			 
			  "<div style='display:inline-block;background:linear-gradient(135deg,#0066CC,#004C99);color:white;padding:3px 12px;border-radius:14px;font-size:11px;font-weight:600;margin-bottom:8px;box-shadow:0 1px 4px rgba(0,102,204,0.2)'>" &
			    SelectedCityName &
			  "</div>" &
			 
			  "<div style='font-size:17px;font-weight:700;color:#1a1a1a;margin-bottom:6px;padding-right:250px;line-height:1.3'>" &
			    MetricName & " Rank: <span style='color:#0066CC;font-weight:700'>#" & CityRank & "</span>" &
			  "</div>" &
			 
			  "<div style='font-size:17px;font-weight:700;color:#1a1a1a;margin-bottom:10px;padding-right:250px;line-height:1.3'>" &
			    "<span style='font-weight:500;color:#666666'>Current Value:</span> <span style='color:#0066CC'>" & FORMAT(SelectedValue, "0.0") & "</span>" &
			    "<span style='font-weight:500;color:#666666;font-size:14px'> pts</span>" &
			  "</div>" &
			 
			  "<div style='font-size:11px;color:#666666;font-weight:400;line-height:1.4'>" &
			    IF(
			        NOT(ISBLANK(TopImprovementValue)) && TopImprovementValue > 0,
			        "Biggest YoY gain: <span style='font-weight:600;color:#1a1a1a'>" & TopImproverName & " (+" & FORMAT(TopImprovementValue, "0.0") & " pts)</span>",
			        "Stable performance across cities"
			    ) & " • Year: " & CurrentYear &
			  "</div>" &
			 
			"</div>"
			```
		lineageTag: 91299b42-0baf-4af6-a474-6e2602720379

	measure 'Tooltip - Gap vs Benchmark' = ```
			
			VAR CurrentValue = [Selected City Metric]
			VAR BenchmarkValue = [All Cities Benchmark]
			VAR Gap = CurrentValue - BenchmarkValue
			
