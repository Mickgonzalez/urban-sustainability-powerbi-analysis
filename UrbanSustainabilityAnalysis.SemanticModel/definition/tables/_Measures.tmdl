	measure 'Page 1 - Ranking Display Sparkline' = ```
			
			VAR CurrentCity = SELECTEDVALUE('City Lookup'[City])
			VAR SelectedYear = SELECTEDVALUE('City Metrics'[Year])
			VAR HasYearFilter = NOT(ISBLANK(SelectedYear))
			
			VAR XMinYear = 2015
			VAR XMaxYear = 2024
			
			VAR SparklineTable = 
			    ADDCOLUMNS(
			        CALCULATETABLE(
			            FILTER(
			                ALL('City Metrics'[Year]),
			                'City Metrics'[Year] >= 2015 && 'City Metrics'[Year] <= 2024
			            )
			        ),
			        "@Year", 'City Metrics'[Year],
			        "@Value", CALCULATE([Selected Metric], 'City Lookup'[City] = CurrentCity),
			        "@X", 5 + INT(74 * DIVIDE('City Metrics'[Year] - XMinYear, XMaxYear - XMinYear))
			    )
			
			VAR YMinValue = MINX(SparklineTable, [@Value])
			VAR YMaxValue = MAXX(SparklineTable, [@Value])
			VAR YRange = YMaxValue - YMinValue
			VAR SafeRange = IF(YRange = 0, 1, YRange)
			
			VAR SparklineTableWithY = 
			    ADDCOLUMNS(
			        SparklineTable,
			        "@Y", 3 + INT(16 * DIVIDE([@Value] - YMinValue, SafeRange))
			    )
			
			VAR Points = 
			    CONCATENATEX(
			        SparklineTableWithY,
			        [@X] & "," & (22 - [@Y]),
			        " ",
			        [@Year],
			        ASC
			    )
			
			VAR ValCurrent = IF(HasYearFilter, CALCULATE([Selected Metric], 'City Lookup'[City] = CurrentCity, 'City Metrics'[Year] = SelectedYear), BLANK())
			VAR ValPrev = IF(HasYearFilter, CALCULATE([Selected Metric], 'City Lookup'[City] = CurrentCity, 'City Metrics'[Year] = SelectedYear - 1), BLANK())
			VAR Diff = ValCurrent - ValPrev
			VAR BulletColor = IF(Diff >= 0, "%230066CC", "%23C75B5B")
			
			VAR SelectedX = IF(HasYearFilter, 5 + INT(74 * DIVIDE(SelectedYear - XMinYear, XMaxYear - XMinYear)), BLANK())
			VAR SelectedY = IF(HasYearFilter, 22 - (3 + INT(16 * DIVIDE(ValCurrent - YMinValue, SafeRange))), BLANK())
			
			
			VAR DotMarker = 
			    IF(
			        HasYearFilter,
			        "<circle cx='" & SelectedX & "' cy='" & SelectedY & "' r='3' fill='" & BulletColor & "' stroke='white' stroke-width='1'>" &
			        "<animate attributeName='opacity' from='0' to='1' dur='0.5s' begin='1s' fill='freeze' />" &
			        "</circle>",
			        ""
			    )
			
			VAR Defs = 
			    "<defs>" &
			    "<linearGradient id='grad" & SUBSTITUTE(CurrentCity, " ", "") & "' x1='0' y1='0' x2='0' y2='22' gradientUnits='userSpaceOnUse'>" &
			    "<stop stop-color='%230066CC' offset='0' />" &
			    "<stop stop-color='transparent' offset='1' />" &
			    "</linearGradient>" &
			    "</defs>"
			
			VAR LineColor = "%23BDBDBD" 
			
			
			VAR SVGImageURL = 
			    IF(
			        NOT(ISBLANK(CurrentCity)),
			        "data:image/svg+xml;utf8," &
			        "<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 84 22'>" & 
			        Defs &
			        "<polyline fill='url(%23grad" & SUBSTITUTE(CurrentCity, " ", "") & ")' fill-opacity='0.2' stroke='" & LineColor & "' stroke-width='1.2' stroke-linecap='round' stroke-linejoin='round' " &
			        "points='0 22 " & Points & " 84 22' stroke-dasharray='500' stroke-dashoffset='500'>" & 
			        "<animate attributeName='stroke-dashoffset' from='500' to='0' dur='1.2s' begin='0s' fill='freeze' />" &
			        "<animate attributeName='fill-opacity' from='0' to='0.2' dur='0.5s' begin='1s' fill='freeze' />" &
			        "</polyline>" &
			        DotMarker &
			        "</svg>",
			        BLANK()
			    )
			
			RETURN SVGImageURL
			```
		lineageTag: 164947c9-b9f8-402d-8f37-c53b7c8191cc
		dataCategory: ImageUrl

	measure 'Page 1 - Ranking Display Gap' = ```
			VAR CurrentYear = MAX('City Metrics'[Year])
			VAR CurrentValue = CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			VAR BenchmarkValue = CALCULATE([All Cities Benchmark], 'City Metrics'[Year] = CurrentYear)
			VAR Gap = CurrentValue - BenchmarkValue
			
			
			VAR AllCitiesGap = 
			    ADDCOLUMNS(
			        ALL('City Lookup'[City]),
			        "@GapValue", 
			            VAR Curr = CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			            VAR Bench = CALCULATE([All Cities Benchmark], 'City Metrics'[Year] = CurrentYear)
			            RETURN Curr - Bench
			    )
			
			VAR Top3Positive = TOPN(3, AllCitiesGap, [@GapValue], DESC)
			VAR Top3Negative = TOPN(3, AllCitiesGap, [@GapValue], ASC)
			VAR CurrentCity = SELECTEDVALUE('City Lookup'[City])
			
			VAR IsTop3Positive = COUNTROWS(FILTER(Top3Positive, 'City Lookup'[City] = CurrentCity)) > 0
			VAR IsTop3Negative = COUNTROWS(FILTER(Top3Negative, 'City Lookup'[City] = CurrentCity)) > 0
			
			
			VAR _BgColor = 
			    IF(IsTop3Positive, "#E3F2FD",     
			    IF(IsTop3Negative, "#FFEBEE",     
			    "transparent"))                   
			
			VAR _TextColor = 
			    IF(IsTop3Positive, "#1565C0",     
			    IF(IsTop3Negative, "#C62828",     
			    "#252423"))                       
			
			VAR FormattedValue = FORMAT(Gap, "+0.0;-0.0")
			
			
			VAR SVGOutput = 
			    "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='75'>
			    <rect x='0' y='0' width='240' height='75' rx='38' fill='" & _BgColor & "'/>
			    <text x='120' y='50' text-anchor='middle' font-family='system-ui,-apple-system,Segoe UI,sans-serif' font-size='40' font-weight='600' letter-spacing='-0.02em' fill='" & _TextColor & "'>" & FormattedValue & "</text>
			    </svg>"
			
			RETURN SVGOutput
			```
		lineageTag: cd43436d-0e98-4e9f-a3bd-afaca417db67
		dataCategory: ImageUrl

	measure 'Page 1 - Ranking YoY Display' = ```
			VAR CurrentYear = MAX('City Metrics'[Year])
			VAR PrevYear = CurrentYear - 1
			VAR CurrentValue = CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			VAR PrevValue = CALCULATE([Selected Metric], 'City Metrics'[Year] = PrevYear)
			VAR Change = CurrentValue - PrevValue
			
			
			VAR AllCitiesYoY = 
			    ADDCOLUMNS(
			        ALL('City Lookup'[City]),
			        "@YoYChange", 
			            VAR Curr = CALCULATE([Selected Metric], 'City Metrics'[Year] = CurrentYear)
			            VAR Prev = CALCULATE([Selected Metric], 'City Metrics'[Year] = PrevYear)
			            RETURN Curr - Prev
			    )
			
			VAR Top3Positive = TOPN(3, AllCitiesYoY, [@YoYChange], DESC)
			VAR Top3Negative = TOPN(3, AllCitiesYoY, [@YoYChange], ASC)
			VAR CurrentCity = SELECTEDVALUE('City Lookup'[City])
			
			VAR IsTop3Positive = COUNTROWS(FILTER(Top3Positive, 'City Lookup'[City] = CurrentCity)) > 0
			VAR IsTop3Negative = COUNTROWS(FILTER(Top3Negative, 'City Lookup'[City] = CurrentCity)) > 0
			
			
			VAR _BgColor = 
			    IF(IsTop3Positive, "#E3F2FD",     
			    IF(IsTop3Negative, "#FFEBEE",     
			    "transparent"))                   
			
			VAR _TextColor = 
			    IF(IsTop3Positive, "#1565C0",     
			    IF(IsTop3Negative, "#C62828",     
			    "#252423"))                       
			
			VAR FormattedValue = FORMAT(Change, "+0.0;-0.0")
			
			
			VAR SVGOutput = 
			    "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='240' height='75'>
			    <rect x='0' y='0' width='240' height='75' rx='38' fill='" & _BgColor & "'/>
			    <text x='120' y='50' text-anchor='middle' font-family='system-ui,-apple-system,Segoe UI,sans-serif' font-size='40' font-weight='600' letter-spacing='-0.02em' fill='" & _TextColor & "'>" & FormattedValue & "</text>
			    </svg>"
			
			RETURN SVGOutput
			```
		lineageTag: 7d04206c-9d89-4e0e-8b10-1fe8e5534879
		dataCategory: ImageUrl

